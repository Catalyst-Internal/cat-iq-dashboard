# Copy to .env.local and fill in.
# .env.local is gitignored. Never commit a real token.
#
# Token scopes required:
#   - public_repo  (REST: repos, issues, PRs, milestones, commits)
#   - read:project (GraphQL: Projects v2 board state)

VITE_GITHUB_TOKEN=ghp_your_token_here
VITE_GITHUB_OWNER=your-github-org-or-user
VITE_GITHUB_REPOS=repo-one,repo-two,repo-three
